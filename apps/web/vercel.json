{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && NODE_OPTIONS=--max-old-space-size=7168 pnpm turbo run build --filter=web --concurrency=1 --no-daemon",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/queue/retry",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/streams/update-workspace-clicks",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "app/(ee)/api/cron/**/*.ts": {
      "maxDuration": 10
    }
  }
}
