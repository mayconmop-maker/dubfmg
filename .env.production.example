# Copy this to .env.production and fill in real values before running:
#   docker compose -f docker-compose.production.yml --env-file .env.production up -d
#
# For the full list of optional variables (Stripe, OAuth providers, etc.)
# see apps/web/.env.example — only the required ones for self-hosting are
# repeated here, minus the payout/partner-program/bounty features this
# deployment doesn't use.

###############################
###### REQUIRED ######
###############################

# App URL — must match the domain you point at this server
NEXTAUTH_URL=https://links.suaempresa.com.br
NEXT_PUBLIC_APP_DOMAIN=links.suaempresa.com.br

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
CRON_SECRET=
ENCRYPTION_KEY=

# MySQL root password, used by the app, mysql and planetscale-proxy services
MYSQL_ROOT_PASSWORD=

# Upstash Redis — https://upstash.com (free tier is enough for internal use)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — https://upstash.com
QSTASH_URL="https://qstash-us-east-1.upstash.io"
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Tinybird — https://tinybird.co (free tier)
TINYBIRD_API_KEY=
TINYBIRD_API_URL=https://api.tinybird.co

# Resend — https://resend.com (free tier), required for login emails
RESEND_API_KEY=

###############################
###### NOT NEEDED HERE ######
###############################
# TEAM_ID_VERCEL / VERCEL_API_KEY: only needed for the in-app "add custom
# domain" button (Vercel Domains API). Skip these and add domains manually
# via DNS + reverse proxy instead.
#
# STRIPE_*, partner/payout/bounty env vars: not needed since this
# deployment doesn't use billing, the affiliate program, or bounties.
